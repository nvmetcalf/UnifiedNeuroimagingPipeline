static void setMinMax(ANA_dsr* dsr, LST_HEAD** l, CTNBOOLEAN floatFlag)
{
  CONDITION cond;
  void * pixels;
  PARAMS *p;
  DCM_OBJECT* obj;
  int pixelCount;
  double rescale=1.0;
  
  float minVal = 65536; /* Assuming unsigned 16 bit converted to float if floatFlag */
  float maxVal = -65536;
  
  if (verbose == 2)printf("setMinMax: Process image list\n");
  
  p = LST_Head(l);
  (void)LST_Position(l, p);
  while (p != NULL) {
  
    unsigned long options = DCM_ORDERLITTLEENDIAN;
    if (p->part10Flag){
       options &= ~DCM_FILEFORMATMASK;
       options |= DCM_PART10FILE;
       options |= DCM_ACCEPTVRMISMATCH;
    }

    if (verbose == 2){
      printf("setMinMax: options = %x\n",options);
      printf("setMinMax:  %s\n", p->fileName);
    }
    
    cond = DCM_OpenFile(p->fileName, options, &obj);
    if (cond != DCM_NORMAL) {
      COND_DumpConditions();
      exit(6);
    }
    
    if (verbose == 2){
      printf("setMinMax: Ready to extractPixels\n");
    }
    
    pixels = extractPixels(&obj, p, floatFlag);
    
    if(p->img_number_frames > 0){
          pixelCount = p->rows * p->columns * p->img_number_frames;
    }else{
          pixelCount = p->rows * p->columns;
    }
    
    if (verbose == 2){
      printf("setMinMax: Returned From extractPixels\n");
    }
    
    if((strcmp(p->idModality,"PT") == 0)) rescale = atof(p->rescale_slope);
     printf("rescale=%.12f\n",rescale);
    
    if (floatFlag) {
    
      float* p1;
      p1 = pixels;
      while(pixelCount-- > 0) {
	
	if((strcmp(p->idModality,"PT") == 0)) *p1 *= rescale;
	
	if (*p1 > maxVal) maxVal = *p1;
	if (*p1 < minVal) minVal = *p1;
	  
	p1++;
      }
    }
    
    if (! floatFlag) {
      
      S16* p1;
      p1 = pixels;
      while(pixelCount-- > 0) {
      
       /*if (p->idModality == "PT") *p1 *= rescale;*/
       
       if (*p1 > maxVal) maxVal = *p1;
       if (*p1 < minVal) minVal = *p1;
    
       p1++;
      }
    }

    free(pixels);
    DCM_CloseObject(&obj);
    p = LST_Next(l);
  }

  dsr->dime.glmax = maxVal;
  dsr->dime.glmin = minVal;
  
  if(verbose)printf("setMinMax: maxVal= %.2f minVal= %.2f\n",maxVal, minVal);
}
