#include <stdlib.h>
#include <stdio.h>

/*******************/
/* DGEEV prototype */
/*******************/
extern void dgeev_ (char* jobvl, char* jobvr, int* n, double* a, int* lda, double* wr, double* wi, double* vl, int* ldvl,
			double* vr, int* ldvr, double* work, int* lwork, int* info);
/*********************************/
/* Auxiliary routines prototypes */
/*********************************/
extern void print_eigenvalues  (char* desc, int n, double* wr, double* wi);
extern void print_eigenvectors (char* desc, int n, double* wi, double* v, int ldv);

/**********************/
/* Auxiliary printing */
/**********************/
void print_eigenvalues (char* desc, int n, double* wr, double* wi) {
	int	j;
	printf ("\n %s\n", desc);
	for (j = 0; j < n; j++ ) {
		if (wi[j] == (double) 0.0) {
			printf (" %6.2f", wr[j]);
		} else {
			printf ("(%6.2f,%6.2f)", wr[j], wi[j]);
		}
	}
	printf ("\n");
}

void print_eigenvectors (char* desc, int n, double* wi, double* v, int ldv) {
	int	i, j;
	printf("\n %s\n", desc);
	for (i = 0; i < n; i++) {
		j = 0;
		while (j < n) {
			if (wi[j] == (double) 0.0) {
				printf (" %6.2f", v[i+j*ldv]);
				j++;
			} else {
				printf ("(%6.2f,%6.2f)", v[i+j*ldv],  v[i+(j+1)*ldv]);
				printf ("(%6.2f,%6.2f)", v[i+j*ldv], -v[i+(j+1)*ldv]);
				j += 2;
			}
		}
		printf ("\n");
	}
}

int run_dgeev (double *a, int n) {
	int	lda, ldvl, ldvr, info, lwork;
	double	wkopt;
	double	*work, *wr, *wi, *vl, *vr;

	lda = ldvl = ldvr = n;
	wr = (double *) malloc (  n*sizeof(double));
	wi = (double *) malloc (  n*sizeof(double));
	vl = (double *) malloc (n*n*sizeof(double));
	vr = (double *) malloc (n*n*sizeof(double));

/********************************************/
/* Query and allocate the optimal workspace */
/********************************************/
	lwork = -1;
	dgeev_ ("Vectors", "Vectors", &n, a, &lda, wr, wi, vl, &ldvl, vr, &ldvr, &wkopt, &lwork, &info);
	lwork = (int) wkopt;
	work = (double *) malloc (lwork*sizeof(double));
/**********************/
/* Solve eigenproblem */
/**********************/
	dgeev_ ("Vectors", "Vectors", &n, a, &lda, wr, wi, vl, &ldvl, vr, &ldvr,  work,  &lwork, &info);
/*************************/
/* Check for convergence */
/*************************/
	if (info) {
		printf ("dgeev_ fail\n" );
		return info;
	}

/*****************/
/* Print results */
/*****************/
	print_eigenvalues  ("Eigenvalues", n, wr, wi);
	print_eigenvectors ("Left  eigenvectors", n, wi, vl, ldvl);
	print_eigenvectors ("Right eigenvectors", n, wi, vr, ldvr);

	free ((void *) work);
	free (wr); free (wi); free (vl); free (vr);
	return 0;
}

